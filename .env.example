# MCE Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# SERVER SETTINGS
# =============================================================================
MCE_HOST=0.0.0.0
MCE_PORT=8000
MCE_LOG_LEVEL=INFO
MCE_DEBUG=false

# =============================================================================
# COMPILER SETTINGS
# =============================================================================
MCE_COMPILE_ON_STARTUP=true
MCE_COMPILED_OUTPUT_DIR=./compiled
MCE_SWAGGER_CONFIG_FILE=./config/swaggers.yaml

# LLM enhancement (optional — requires litellm package: pip install mce[llm])
# MCE_LLM_MODEL uses LiteLLM naming convention — examples:
#   OpenAI:      openai/gpt-4o
#   Anthropic:   anthropic/claude-3-5-sonnet-20241022
#   Gemini:      gemini/gemini-2.0-flash
#   OpenRouter:  openrouter/mistralai/mistral-7b-instruct
MCE_LLM_ENHANCE=false
MCE_LLM_API_KEY=
MCE_LLM_MODEL=gemini/gemini-2.0-flash

# =============================================================================
# EXECUTOR SETTINGS
# =============================================================================
MCE_LINT_ENABLED=false
MCE_DOCKER_IMAGE=mce-sandbox:latest
MCE_EXECUTION_TIMEOUT_SECONDS=30
MCE_MAX_OUTPUT_SIZE_BYTES=1048576
MCE_NETWORK_MODE=mce_network

# Sandbox execution mode (default: warm)
#   warm  — persistent container pool; eliminates per-request cold-start latency (~100–400 ms)
#   cold  — new container per request; maximum per-request isolation, higher latency
MCE_SANDBOX_MODE=warm

# Number of persistent containers to keep alive in warm mode (default: 2).
# Increase if you see "all warm containers are busy" under concurrent load.
MCE_WARM_POOL_SIZE=2

# =============================================================================
# CACHE SETTINGS
# =============================================================================
MCE_CACHE_ENABLED=true
MCE_CACHE_TTL_SECONDS=3600
MCE_CACHE_MAX_ENTRIES=500
MCE_CACHE_DB_PATH=./data/cache.db

# =============================================================================
# SECURITY
# =============================================================================
MCE_MAX_CODE_SIZE_BYTES=65536
# Comma-separated allowed API domains (empty = allow all)
# MCE_ALLOWED_DOMAINS=api.weather.example.com,api.hotel.example.com

# =============================================================================
# API SERVER CREDENTIALS
# Format: MCE_{SERVER_NAME_UPPER}_BASE_URL and MCE_{SERVER_NAME_UPPER}_AUTH
# =============================================================================

# Weather API
MCE_WEATHER_BASE_URL=https://api.weather.example.com/v1
MCE_WEATHER_AUTH=Authorization: Bearer your-weather-api-key-here

# Hotel API
MCE_HOTEL_BASE_URL=https://api.hotel.example.com/v2
MCE_HOTEL_AUTH=Authorization: Bearer your-hotel-api-token-here
